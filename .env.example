# Redi – copy to .env and set in production. Do not commit .env or serviceAccountKey.json.

# Server port (default: 8080)
REDI_PORT=8080

# JWT signing secret – set a long random string in production
REDI_JWT_SECRET=your-secret-at-least-32-chars

# Firebase (from your Firebase project settings)
REDI_FIREBASE_PROJECT_ID=your-project-id
REDI_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Path to the service account JSON key file (download from Firebase Console → Project settings → Service accounts)
REDI_FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json
